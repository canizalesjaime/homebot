{
  "name": "Ros2-Setup",
  "build": {
    "dockerfile": "./humble_pi.Dockerfile"
  },
  "runArgs": [
    "--init",
    "--privileged",
    "--net=host",
    "--device=/dev/gpiomem",
    "--device=/dev/mem",
    "--device=/dev/ttyAMA0",
    "--cap-add=SYS_RAWIO",
    "--env=DISPLAY",
    "--env=QT_X11_NO_MITSHM=1",
    "--volume=/tmp/.X11-unix:/tmp/.X11-unix:rw"
  ],
  "mounts": [
    "source=/sys/class/gpio,target=/sys/class/gpio,type=bind,consistency=cached",
    "source=/dev,target=/dev,type=bind",
    "source=/run,target=/run,type=bind"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.cpptools"
      ]
    }
  },

  "remoteUser": "root",
  "containerEnv": {
    "LIBCAMERA_LOG_LEVELS": "3"
  }
}
