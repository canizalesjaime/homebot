{
    "name": "Ros2-Setup",
    "build" : {
        "dockerfile": "./humble_pi.Dockerfile"
    },
    
    "runArgs": [
    "--init",
    "--privileged",
    "--device=/dev/gpiomem",
    "--device=/dev/mem",
    "--device=/dev/ttyAMA0",
    "--cap-add=SYS_RAWIO",
    "--net=host"
  ],
  
  "mounts": [
    "source=/sys/class/gpio,target=/sys/class/gpio,type=bind,consistency=cached"
  ],
  "remoteUser": "root",
  "features": {}
}